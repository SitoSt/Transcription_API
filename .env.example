# Transcription Server — example configuration
# Copy this file to .env and fill in the values.
# Variables already set in the environment take precedence over this file.
# CLI arguments override everything.

# Path to the Whisper GGML model file
# Inside Docker the ./models/ directory is mounted at /app/models/
MODEL_PATH=/app/models/ggml-medium.bin

# Server bind address and port
BIND_ADDRESS=0.0.0.0
PORT=8003

# Auth API (leave AUTH_API_URL empty to disable authentication)
AUTH_API_URL=http://internal-api
AUTH_API_SECRET=your_secret_key_here
AUTH_CACHE_TTL=300
AUTH_API_TIMEOUT=5

# Whisper quality tuning
WHISPER_BEAM_SIZE=5
WHISPER_THREADS=4
MAX_CONCURRENT_INFERENCE=4
MODEL_CACHE_TTL=300
#WHISPER_INITIAL_PROMPT="Transcripción en español de España"

# TLS (leave empty to use plain WS)
TLS_CERT=server.crt
TLS_KEY=server.key

# Connection limits
MAX_CONNECTIONS=8
MAX_CONNECTIONS_PER_IP=2

